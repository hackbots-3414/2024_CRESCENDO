 
<configuration> 
 <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
   <encoder>
     <pattern>%date{mm:ss.SSS} [%thread] %-5level %logger{20} - %message %n</pattern>
   </encoder>
 </appender>

  <appender name="FILE" class="ch.qos.logback.core.FileAppender">
    <file>testFile.log</file>
    <append>false</append>
    <!-- set immediateFlush to false for much higher logging throughput -->
    <immediateFlush>true</immediateFlush>
   <encoder>
     <pattern>%date{mm:ss.SSS} [%thread] %-5level %logger{20} - %message %n</pattern>
   </encoder>
 </appender>
 
 <logger name="frc.robot.subsystems.NoteFinder" level="TRACE"/>
 <logger name = "frc.robot.commands.ActivateNearNote" level="WARN"/>
 <logger name = "frc.robot.commands.ActivateNearNoteAndAlign" level="WARN"/>
 <logger name = "frc.robot.commands.ApproachAlignIntake" level="TRACE"/>
  <logger name = "frc.robot.subsystems.CommandSwerveDrivetrain" level="DEBUG"/>
 <root level = "WARN">
   <appender-ref ref="STDOUT"/>
   <appender-ref ref="FILE"/>
 </root>

</configuration>